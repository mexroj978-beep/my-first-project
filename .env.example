# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Ma'lumotlar bazasi
DATABASE_URL=sqlite+aiosqlite:///./school_attendance.db

# Turniket webhook xavfsizligi
WEBHOOK_SECRET=change-me-in-production

# Admin API kaliti
ADMIN_API_KEY=admin-secret-key

# Vaqt zonasi
TIMEZONE=Asia/Tashkent

# To'lov (avtomatik obuna)
APP_BASE_URL=http://localhost:8000
PAYMENT_DEMO_MODE=true
PAYMENT_WEBHOOK_SECRET=payment-secret-key

# Click to'lov (https://click.uz) — ixtiyoriy, ulanganda avtomatik ishlaydi
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
