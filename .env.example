# Telegram bot token (@BotFather dan oling)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Tirniket tizimidan keladigan so'rovlarni himoya qilish uchun maxfiy kalit
TURNSTILE_API_KEY=your_secret_api_key_here

# Ma'lumotlar bazasi (standart: SQLite)
DATABASE_URL=sqlite:///./school.db

# Admin panel uchun maxfiy kalit (o'quvchilarni qo'shish uchun)
ADMIN_API_KEY=your_admin_secret_here

# Maktab nomi (xabarlarda ko'rinadi)
SCHOOL_NAME=Maktab nomi

# Server porti
PORT=8000
