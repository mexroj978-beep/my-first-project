# Telegram
TELEGRAM_BOT_TOKEN=

# Admin (production da murakkab kalitlar qo'ying!)
ADMIN_API_KEY=admin-secret-key
WEBHOOK_SECRET=change-me-in-production

# Ma'lumotlar bazasi
# SQLite (mahalliy test):
DATABASE_URL=sqlite+aiosqlite:///./xabarnoma.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://xabarnoma:PAROL@localhost:5432/xabarnoma

# Vaqt
TIMEZONE=Asia/Tashkent

# Server manzili (production: HTTPS)
APP_BASE_URL=http://localhost:8000
# APP_BASE_URL=https://xabarnoma.example.com

# nginx/Cloudflare orqasida haqiqiy mijoz IP si
TRUST_PROXY_HEADERS=false

# Turniket / Face ID webhook IP whitelist (vergul bilan; bo'sh = hamma ruxsat)
TURNSTILE_IP_WHITELIST=

# To'lov
PAYMENT_DEMO_MODE=true
PAYMENT_WEBHOOK_SECRET=payment-secret

# Click (ixtiyoriy - https://click.uz)
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
